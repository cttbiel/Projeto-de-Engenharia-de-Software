# Copie para `.env` na pasta frontend (não commite `.env` com segredos).

# URL do back-end Flask. Se estiver vazia ou ausente → login/cadastro só no navegador (recomendado na Vercel).
# VITE_API_URL=http://localhost:5000

# Opcional: true = força modo navegador | false = força API
# VITE_USE_MOCK_AUTH=true
